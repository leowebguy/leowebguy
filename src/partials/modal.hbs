<div class="modal fade" id="{{ id }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form name="contact">
                <div class="modal-header bg-secondary">
                    <h4 class="modal-title text-dark">Reach out</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <fieldset>
                        <input type="text" name="name" class="form-control mb-3" placeholder="Name (required)" maxlength="60" autocomplete="name" required>
                        <input type="email" name="email" class="form-control mb-3" placeholder="Email (required)" autocomplete="email" required>
                        <input type="tel" name="phone" class="form-control mb-3" placeholder="Phone" autocomplete="tel">
                        <textarea name="msg" class="form-control mb-3" rows="6" placeholder="Your message here (required)" maxlength="255" required></textarea>
                        <div class="d-flex justify-content-end gap-3">
                            <div class="cf-turnstile" data-sitekey="0x4AAAAAAB-GblMAsuRg1SAB"></div>
                            <button type="submit" class="btn btn-lg btn-secondary px-5">Send</button>
                        </div>
                    </fieldset>
                    <div class="alert alert-light success d-none w-100">
                        <span>Thanks for your message!<br>I'll reach out as soon as possible.</span>
                    </div>
                    <div class="alert alert-warning warning d-none w-100">
                        <span>Sorry, something went wrong. Please send an email to leowebguy@gmail.com</span>
                    </div>
                    <div class="alert alert-warning turnstile d-none w-100">
                        <span>Please complete the turnstile</span>
                    </div>
                </div>
                {{!-- <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Send</button>
                </div> --}}
            </form>
        </div>
    </div>
</div>
